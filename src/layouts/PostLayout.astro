---
import { Image } from "astro:assets";
import BaseLayout from "./BaseLayout.astro";

const { frontmatter } = Astro.props;
---

<BaseLayout>
    <article class="mx-auto text-justify flex flex-col gap-10">
        <div class="flex flex-col gap-2">
            <h2 class="text-4xl font-mono">{frontmatter.title}</h2>
            <p>
                Published on: {frontmatter.pubDate.toString().slice(0, 10)} by <i
                    class="text-accent">{frontmatter.author}</i
                >
            </p>
            <p><em class="text-tertiary">{frontmatter.description}</em></p>
            <Image src={frontmatter.image.url} alt={frontmatter.image.alt} />
            <p class="text-right text-xs">
                <em class="text-tertiary"
                    >Photo by <a href={frontmatter.image.author.url}
                        >{frontmatter.image.author.name}</a
                    > on <a href={frontmatter.image.site.url}>
                        {frontmatter.image.site.name}</a
                    >
                </em>
            </p>
        </div>
        <div>
            <slot />
        </div>
    </article>
</BaseLayout>
